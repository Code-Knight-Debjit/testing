# ─────────────────────────────────────────────
# DJANGO CORE
# ─────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# DATABASE — SQLite default (dev) / PostgreSQL (prod)
# ─────────────────────────────────────────────
DB_ENGINE=django.db.backends.sqlite3
# DB_ENGINE=django.db.backends.postgresql
DB_NAME=db.sqlite3
# DB_NAME=anupam_bearings_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────
# EMAIL (Resend API)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=noreply@anupambearings.com
COMPANY_EMAIL=info@anupambearings.com

# ─────────────────────────────────────────────
# OLLAMA (Local LLM)
# ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
# To switch models: llama3, mistral, llama3.2, gemma2, phi3
OLLAMA_MAX_CONCURRENT=4
OLLAMA_TIMEOUT=45
OLLAMA_MAX_RETRIES=2

# ─────────────────────────────────────────────
# REDIS (Celery broker + RAG cache)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# RAG SYSTEM
# ─────────────────────────────────────────────
RAG_INDEX_DIR=data/faiss_index
RAG_KNOWLEDGE_DIR=data/knowledge_base
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.22
EMBEDDING_MODEL=all-MiniLM-L6-v2
